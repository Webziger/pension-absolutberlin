---
import { Icon } from 'astro-icon/components';

const nav = [
  { href: '#zimmer', label: 'Zimmer' },
  { href: '#vorteile', label: 'Vorteile' },
  { href: '#bewertungen', label: 'Bewertungen' },
  { href: '#lage', label: 'Lage' },
  { href: '#faq', label: 'FAQ' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-zinc-200/80 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-site items-center justify-between gap-4 px-4 md:h-[72px] md:px-6">
    <a href="#top" class="shrink-0" aria-label="Pension Absolut Berlin, zur Startseite">
      <img src="/img/logo.png" alt="Pension Absolut Berlin" width="130" height="65" class="h-10 w-auto md:h-12" />
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Hauptnavigation">
      {nav.map((item) => (
        <a href={item.href} class="text-[15px] font-bold text-zinc-700 transition-colors hover:text-brand">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <a
        href="tel:+493096065020"
        class="hidden items-center gap-1.5 text-[15px] font-bold text-zinc-700 transition-colors hover:text-brand md:flex"
      >
        <Icon name="ph:phone-bold" class="h-4 w-4 text-brand" aria-hidden="true" />
        030 960 650 20
      </a>
      <a
        href="tel:+493096065020"
        class="flex h-10 w-10 items-center justify-center rounded-full text-zinc-700 transition-colors hover:text-brand md:hidden"
        aria-label="Anrufen: 030 960 650 20"
      >
        <Icon name="ph:phone-bold" class="h-5 w-5" aria-hidden="true" />
      </a>
      <a
        href="https://app.mews.com/distributor/e7d93a6a-92c6-4444-9b65-b1780078713a"
        target="_blank"
        rel="noopener"
        class="mews-open rounded-full bg-brand px-4 py-2 text-[15px] font-bold text-white shadow-sm transition-all hover:bg-brand-dark active:scale-[0.98] md:px-5 md:py-2.5"
      >
        Jetzt buchen
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="flex h-10 w-10 items-center justify-center rounded-full text-zinc-700 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Menü öffnen"
      >
        <Icon name="ph:list-bold" class="h-6 w-6" aria-hidden="true" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-zinc-200 bg-white lg:hidden">
    <nav class="mx-auto flex max-w-site flex-col px-4 py-2" aria-label="Mobile Navigation">
      {nav.map((item) => (
        <a href={item.href} class="border-b border-zinc-100 py-3 text-base font-bold text-zinc-700 last:border-0">
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  var toggle = document.getElementById('menu-toggle');
  var menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', function () {
      var open = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });
    menu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
