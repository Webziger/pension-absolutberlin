---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import einzel from '../assets/img/zimmer-einzel.jpg';
import doppel from '../assets/img/zimmer-doppel.jpg';
import dreibett from '../assets/img/zimmer-dreibett.jpg';
import mehrbett from '../assets/img/zimmer-mehrbett.jpg';
import apartment from '../assets/img/zimmer-apartment.jpg';

const nav = [
  { href: '#vorteile', label: 'Vorteile' },
  { href: '#bewertungen', label: 'Bewertungen' },
  { href: '#lage', label: 'Lage' },
  { href: '#faq', label: 'FAQ' },
  { href: '#kontakt', label: 'Kontakt' },
];

const roomPreviews = [
  { img: einzel, name: 'Einzelzimmer', text: 'Kompakt und ruhig für eine Person' },
  { img: doppel, name: 'Doppelzimmer', text: 'Unser beliebtestes Zimmer für zwei' },
  { img: dreibett, name: 'Dreibettzimmer', text: 'Platz für Familien mit Kind' },
  { img: mehrbett, name: 'Mehrbettzimmer', text: 'Günstig für Gruppen' },
  { img: apartment, name: 'Serviced Apartment', text: 'Wohnen auf Zeit mit Küche' },
];
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-zinc-200/80 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-site items-center justify-between gap-4 px-4 md:h-[72px] md:px-6">
    <a href="#top" class="shrink-0" aria-label="Pension Absolut Berlin, zur Startseite">
      <img src="/img/logo.png" alt="Pension Absolut Berlin" width="130" height="65" class="h-10 w-auto md:h-12" />
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Hauptnavigation">
      <!-- Megamenü-Trigger: Zimmer mit Vorschau-Panel -->
      <button
        id="megamenu-toggle"
        type="button"
        class="flex items-center gap-1 text-[15px] font-bold text-zinc-700 transition-colors hover:text-brand"
        aria-expanded="false"
        aria-controls="megamenu"
      >
        Zimmer
        <Icon id="megamenu-caret" name="ph:caret-down-bold" class="h-3.5 w-3.5 transition-transform duration-200" aria-hidden="true" />
      </button>
      {nav.map((item) => (
        <a href={item.href} class="text-[15px] font-bold text-zinc-700 transition-colors hover:text-brand">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <a
        href="tel:+493096065020"
        class="hidden items-center gap-1.5 text-[15px] font-bold text-zinc-700 transition-colors hover:text-brand md:flex"
      >
        <Icon name="ph:phone-bold" class="h-4 w-4 text-brand" aria-hidden="true" />
        030 960 650 20
      </a>
      <a
        href="tel:+493096065020"
        class="flex h-10 w-10 items-center justify-center rounded-full text-zinc-700 transition-colors hover:text-brand md:hidden"
        aria-label="Anrufen: 030 960 650 20"
      >
        <Icon name="ph:phone-bold" class="h-5 w-5" aria-hidden="true" />
      </a>
      <a
        href="https://app.mews.com/distributor/e7d93a6a-92c6-4444-9b65-b1780078713a"
        target="_blank"
        rel="noopener"
        class="mews-open rounded-full bg-brand px-4 py-2 text-[15px] font-bold text-white shadow-sm transition-all hover:bg-brand-dark active:scale-[0.98] md:px-5 md:py-2.5"
      >
        Jetzt buchen
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="flex h-10 w-10 items-center justify-center rounded-full text-zinc-700 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Menü öffnen"
      >
        <Icon name="ph:list-bold" class="h-6 w-6" aria-hidden="true" />
      </button>
    </div>
  </div>

  <!-- Megamenü-Panel (Desktop): Zimmer-Vorschau mit gleich großen Bildern -->
  <div id="megamenu" class="border-t border-zinc-200 bg-white shadow-xl shadow-zinc-900/10 max-lg:!hidden" hidden>
    <div class="mx-auto grid max-w-site grid-cols-5 gap-5 px-6 py-6">
      {roomPreviews.map((room) => (
        <a href="#zimmer" class="megamenu-link group">
          <Image
            src={room.img}
            alt={`${room.name} der Pension Absolut Berlin`}
            class="h-28 w-full rounded-2xl object-cover transition-transform duration-300 group-hover:scale-[1.03]"
            widths={[320, 480]}
            sizes="18vw"
          />
          <p class="mt-2.5 text-[15px] font-black text-ink transition-colors group-hover:text-brand">{room.name}</p>
          <p class="text-sm leading-snug text-zinc-600">{room.text}</p>
        </a>
      ))}
    </div>
  </div>

  <!-- Mobile-Menü: Zimmer als Accordion mit Vorschau-Thumbnails -->
  <div id="mobile-menu" class="hidden max-h-[calc(100dvh-4rem)] overflow-y-auto border-t border-zinc-200 bg-white lg:hidden">
    <nav class="mx-auto flex max-w-site flex-col px-4 py-2" aria-label="Mobile Navigation">
      <details class="border-b border-zinc-100">
        <summary class="flex cursor-pointer items-center justify-between py-3 text-base font-bold text-zinc-700">
          Zimmer
          <Icon name="ph:caret-down-bold" class="faq-chevron h-4 w-4 text-brand transition-transform duration-300" aria-hidden="true" />
        </summary>
        <div class="grid gap-3 pb-4">
          {roomPreviews.map((room) => (
            <a href="#zimmer" class="mobile-menu-link flex items-center gap-3">
              <Image
                src={room.img}
                alt={`${room.name} der Pension Absolut Berlin`}
                class="h-14 w-14 shrink-0 rounded-xl object-cover"
                widths={[112, 168]}
                sizes="56px"
              />
              <span>
                <span class="block text-[15px] font-bold text-ink">{room.name}</span>
                <span class="block text-sm text-zinc-600">{room.text}</span>
              </span>
            </a>
          ))}
        </div>
      </details>
      {nav.map((item) => (
        <a href={item.href} class="mobile-menu-link border-b border-zinc-100 py-3 text-base font-bold text-zinc-700 last:border-0">
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    // Mobile-Menü
    var toggle = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', function () {
        var open = menu.classList.toggle('hidden') === false;
        toggle.setAttribute('aria-expanded', String(open));
      });
      menu.querySelectorAll('.mobile-menu-link').forEach(function (link) {
        link.addEventListener('click', function () {
          menu.classList.add('hidden');
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // Megamenü (Desktop): öffnet per Klick oder Hover, schließt bei Klick außerhalb, Escape oder Linkklick
    var megaToggle = document.getElementById('megamenu-toggle');
    var mega = document.getElementById('megamenu');
    if (!megaToggle || !mega) return;
    var caret = megaToggle.querySelector('svg');
    var hoverTimer = null;
    var openedByHoverAt = 0;

    function setOpen(open) {
      mega.hidden = !open;
      megaToggle.setAttribute('aria-expanded', String(open));
      if (caret) caret.style.transform = open ? 'rotate(180deg)' : '';
    }

    megaToggle.addEventListener('click', function () {
      // Direkt nach Hover-Öffnung nicht wieder schließen (mouseenter feuert vor click)
      if (Date.now() - openedByHoverAt < 600) {
        setOpen(true);
      } else {
        setOpen(mega.hidden);
      }
    });
    megaToggle.addEventListener('mouseenter', function () {
      clearTimeout(hoverTimer);
      if (mega.hidden) openedByHoverAt = Date.now();
      setOpen(true);
    });
    [megaToggle, mega].forEach(function (el) {
      el.addEventListener('mouseleave', function () {
        hoverTimer = setTimeout(function () {
          if (!mega.matches(':hover') && !megaToggle.matches(':hover')) setOpen(false);
        }, 150);
      });
      el.addEventListener('mouseenter', function () {
        clearTimeout(hoverTimer);
      });
    });
    document.addEventListener('click', function (ev) {
      if (!mega.hidden && !mega.contains(ev.target) && !megaToggle.contains(ev.target)) setOpen(false);
    });
    document.addEventListener('keydown', function (ev) {
      if (ev.key === 'Escape') setOpen(false);
    });
    mega.querySelectorAll('.megamenu-link').forEach(function (link) {
      link.addEventListener('click', function () {
        setOpen(false);
      });
    });
  })();
</script>
