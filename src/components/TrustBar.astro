---
import { Icon } from 'astro-icon/components';

const items = [
  { icon: 'ph:clock-bold', label: '24-Stunden-Check-in' },
  { icon: 'ph:wifi-high-bold', label: 'Gratis WLAN' },
  { icon: 'ph:map-pin-bold', label: 'Top-Lage Prenzlauer Berg' },
  { icon: 'ph:tag-bold', label: 'Faire Preise' },
  { icon: 'ph:sparkle-bold', label: 'Täglich gereinigte Zimmer' },
];
---

<section class="border-b border-zinc-200 bg-zinc-50">
  <div
    class="mx-auto grid max-w-site grid-cols-2 gap-x-4 gap-y-5 px-4 py-6 sm:grid-cols-3 md:grid-cols-5 md:px-6 md:py-7"
  >
    {items.map((item) => (
      <div class="flex items-center gap-2.5">
        <Icon name={item.icon} class="h-6 w-6 shrink-0 text-brand" aria-hidden="true" />
        <span class="text-[15px] font-bold leading-tight text-zinc-800">{item.label}</span>
      </div>
    ))}
  </div>
</section>
