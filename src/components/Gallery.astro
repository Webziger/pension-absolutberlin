---
import { Image } from 'astro:assets';
import galerie1 from '../assets/img/galerie-1.jpg';
import fruehstueck from '../assets/img/zimmer-fruehstueck.jpg';
import homeBottom from '../assets/img/home-bottom.jpg';
import fair from '../assets/img/fair.jpg';
import galerieBtn from '../assets/img/galerie-btn.jpg';
import apartment2 from '../assets/img/apartment-2.jpg';

const tiles = [
  { img: galerie1, alt: 'Zimmeransicht der Pension Absolut Berlin', span: 'md:col-span-2 md:row-span-2' },
  { img: fruehstueck, alt: 'Gedeckter Tisch in der Gemeinschaftsküche', span: '' },
  { img: fair, alt: 'Detailansicht eines Zimmers', span: '' },
  { img: apartment2, alt: 'Wohnbereich eines Serviced Apartments', span: 'md:col-span-2' },
  { img: galerieBtn, alt: 'Eingerichtetes Gästezimmer', span: '' },
  { img: homeBottom, alt: 'Blick in die Pension Absolut Berlin', span: '' },
];
---

<section class="mx-auto max-w-site px-4 py-16 md:px-6 md:py-24">
  <h2 class="reveal text-3xl font-black leading-tight md:text-5xl">Ein Blick ins Haus</h2>

  <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4 md:grid-rows-2">
    {tiles.map((tile) => (
      <div class={`reveal group overflow-hidden rounded-2xl ${tile.span}`}>
        <Image
          src={tile.img}
          alt={tile.alt}
          class="h-64 w-full object-cover transition-transform duration-500 group-hover:scale-[1.04] md:h-full md:min-h-[220px]"
          widths={[480, 768, 1200]}
          sizes="(min-width: 768px) 50vw, 100vw"
        />
      </div>
    ))}
  </div>
</section>
