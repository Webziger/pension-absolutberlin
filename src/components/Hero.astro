---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import heroImg from '../assets/img/hero.jpg';
import doppel from '../assets/img/zimmer-doppel.jpg';
import fruehstueck from '../assets/img/zimmer-fruehstueck.jpg';
import galerie1 from '../assets/img/galerie-1.jpg';
---

<section id="top" class="bg-white pt-24 md:pt-32">
  <div class="mx-auto max-w-site px-4 text-center md:px-6">
    <h1 class="mx-auto max-w-3xl text-4xl font-black leading-[1.05] md:text-6xl">
      Übernachten im Prenzlauer Berg. Zentral, fair, familiär.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-zinc-600 md:text-xl">
      Unkompliziert übernachten mit 24-Stunden-Check-in, gratis WLAN und Gemeinschaftsküche, wenige
      Minuten vom Alexanderplatz.
    </p>

    <!-- Buchungsleiste im Airbnb-Stil: übergibt Daten an das echte Mews-Buchungssystem -->
    <form
      id="booking-form"
      class="mx-auto mt-8 flex w-full max-w-3xl flex-col gap-3 rounded-3xl border border-zinc-200 bg-white p-4 text-left shadow-xl shadow-zinc-900/5 md:flex-row md:items-center md:gap-0 md:rounded-full md:p-2 md:pl-8"
      aria-label="Verfügbarkeit prüfen"
    >
      <div class="flex flex-1 flex-col gap-1 md:pr-6">
        <label for="arrival" class="text-sm font-bold text-zinc-700">Anreise</label>
        <input
          type="date"
          id="arrival"
          name="arrival"
          class="h-8 rounded-lg bg-transparent text-[15px] text-ink focus:outline-none focus:ring-2 focus:ring-brand/30 max-md:h-11 max-md:border max-md:border-zinc-300 max-md:px-3"
        />
      </div>
      <div class="flex flex-1 flex-col gap-1 md:border-l md:border-zinc-200 md:px-6">
        <label for="departure" class="text-sm font-bold text-zinc-700">Abreise</label>
        <input
          type="date"
          id="departure"
          name="departure"
          class="h-8 rounded-lg bg-transparent text-[15px] text-ink focus:outline-none focus:ring-2 focus:ring-brand/30 max-md:h-11 max-md:border max-md:border-zinc-300 max-md:px-3"
        />
      </div>
      <div class="flex flex-1 flex-col gap-1 md:border-l md:border-zinc-200 md:px-6">
        <label for="guests" class="text-sm font-bold text-zinc-700">Gäste</label>
        <select
          id="guests"
          name="guests"
          class="h-8 rounded-lg bg-transparent text-[15px] text-ink focus:outline-none focus:ring-2 focus:ring-brand/30 max-md:h-11 max-md:border max-md:border-zinc-300 max-md:px-3"
        >
          <option value="1">1 Gast</option>
          <option value="2" selected>2 Gäste</option>
          <option value="3">3 Gäste</option>
          <option value="4">4 Gäste</option>
          <option value="5">5 und mehr Gäste</option>
        </select>
      </div>
      <button
        type="submit"
        class="flex h-12 items-center justify-center gap-2 rounded-full bg-brand px-6 text-base font-bold text-white transition-all hover:bg-brand-dark active:scale-[0.98] md:h-14 md:shrink-0"
      >
        <Icon name="ph:magnifying-glass-bold" class="h-5 w-5" aria-hidden="true" />
        Verfügbarkeit prüfen
      </button>
    </form>
  </div>

  <!-- Asymmetrisch versetzte Bild-Collage am Ende der Hero-Sektion -->
  <div class="mx-auto max-w-site px-4 pb-16 pt-10 md:px-6 md:pb-20 md:pt-14">
    <div class="grid grid-cols-2 items-start gap-4 md:grid-cols-4 md:gap-5">
      <div class="md:mt-10">
        <Image
          src={fruehstueck}
          alt="Gedeckter Tisch in der Gemeinschaftsküche der Pension Absolut Berlin"
          class="h-48 w-full rounded-3xl object-cover md:h-64"
          widths={[480, 768]}
          sizes="(min-width: 768px) 25vw, 50vw"
          loading="eager"
        />
      </div>
      <div class="mt-6 md:mt-0">
        <Image
          src={heroImg}
          alt="Helles Zimmer der Pension Absolut Berlin im Prenzlauer Berg"
          class="h-48 w-full rounded-3xl object-cover md:h-64"
          widths={[480, 768, 1024]}
          sizes="(min-width: 768px) 25vw, 50vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="md:mt-16">
        <Image
          src={doppel}
          alt="Doppelzimmer der Pension Absolut Berlin"
          class="h-48 w-full rounded-3xl object-cover md:h-64"
          widths={[480, 768]}
          sizes="(min-width: 768px) 25vw, 50vw"
        />
      </div>
      <div class="mt-6 md:mt-6">
        <Image
          src={galerie1}
          alt="Zimmeransicht der Pension Absolut Berlin"
          class="h-48 w-full rounded-3xl object-cover md:h-64"
          widths={[480, 768]}
          sizes="(min-width: 768px) 25vw, 50vw"
        />
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Sinnvolle Vorbelegung: Anreise heute + 7 Tage, Abreise + 9 Tage
  (function () {
    function fmt(d) {
      return d.toISOString().slice(0, 10);
    }
    var arrival = document.getElementById('arrival');
    var departure = document.getElementById('departure');
    if (!arrival || !departure) return;
    var a = new Date();
    a.setDate(a.getDate() + 7);
    var b = new Date();
    b.setDate(b.getDate() + 9);
    arrival.value = fmt(a);
    departure.value = fmt(b);
    arrival.min = fmt(new Date());
    departure.min = fmt(new Date());
    arrival.addEventListener('change', function () {
      if (departure.value <= arrival.value) {
        var next = new Date(arrival.value);
        next.setDate(next.getDate() + 1);
        departure.value = fmt(next);
      }
      departure.min = arrival.value;
    });
  })();
</script>
