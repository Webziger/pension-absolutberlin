---
import { Icon } from 'astro-icon/components';
---

<section id="kontakt" class="bg-brand py-16 md:py-20">
  <div class="mx-auto flex max-w-site flex-col items-start gap-8 px-4 md:flex-row md:items-center md:justify-between md:px-6">
    <div class="reveal max-w-xl">
      <h2 class="text-3xl font-black leading-tight text-white md:text-5xl">
        Ihr Zimmer im Prenzlauer Berg wartet.
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-white/90">
        Buchen Sie direkt bei uns zum besten Preis, oder rufen Sie an. Wir helfen persönlich weiter.
      </p>
    </div>

    <div class="reveal flex flex-col gap-4">
      <a
        href="https://app.mews.com/distributor/e7d93a6a-92c6-4444-9b65-b1780078713a"
        target="_blank"
        rel="noopener"
        class="mews-open inline-flex items-center justify-center gap-2 rounded-full bg-white px-8 py-4 text-lg font-black text-brand shadow-md transition-all hover:bg-zinc-100 active:scale-[0.98]"
      >
        <Icon name="ph:calendar-check-bold" class="h-6 w-6" aria-hidden="true" />
        Jetzt buchen
      </a>
      <div class="flex flex-col gap-1.5 text-white">
        <a href="tel:+493096065020" class="flex items-center gap-2 font-bold hover:underline">
          <Icon name="ph:phone-bold" class="h-4 w-4" aria-hidden="true" />
          +49 30 960 650 20
        </a>
        <a href="mailto:info@pension-absolutberlin.de" class="flex items-center gap-2 font-bold hover:underline">
          <Icon name="ph:envelope-simple-bold" class="h-4 w-4" aria-hidden="true" />
          info@pension-absolutberlin.de
        </a>
      </div>
    </div>
  </div>
</section>
