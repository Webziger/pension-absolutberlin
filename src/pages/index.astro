---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Rooms from '../components/Rooms.astro';
import Why from '../components/Why.astro';
import Reviews from '../components/Reviews.astro';
import Location from '../components/Location.astro';
import Gallery from '../components/Gallery.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Pension Absolut Berlin | Günstige Pension im Prenzlauer Berg"
  description="Familiär geführte Pension im Prenzlauer Berg: faire Preise, 24-Stunden-Check-in, gratis WLAN und zentrale Lage nahe Alexanderplatz. Jetzt direkt buchen."
>
  <Header />
  <main>
    <Hero />
    <TrustBar />
    <Rooms />
    <Why />
    <Reviews />
    <Location />
    <Gallery />
    <Faq />
    <FinalCta />
  </main>
  <Footer />
</Base>
